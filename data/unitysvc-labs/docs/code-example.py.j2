import smtplib
import os
from email.mime.text import MIMEText

{% if local_testing %}
# Local testing: connect directly to upstream SMTP
smtp_host = os.environ.get('HOST', 'localhost')
smtp_port = int(os.environ.get('PORT', '587'))
username = os.environ.get('USERNAME', '')
password = os.environ.get('PASSWORD', '')
{% else %}
# Access via UnitySVC SMTP gateway
# SERVICE_BASE_URL is e.g. smtps://smtp.svcpass.com:587
# Username is the service name (routing_key), password is your API key
from urllib.parse import urlparse
parsed = urlparse(os.environ['SERVICE_BASE_URL'])
smtp_host = parsed.hostname
smtp_port = parsed.port or 587
use_ssl = parsed.scheme == 'smtps'
username = os.environ.get('SERVICE', '{{ offering.name }}')
password = os.environ['UNITYSVC_API_KEY']
{% endif %}

# Compose a test email
msg = MIMEText('Hello from UnitySVC SMTP Gateway!')
msg['Subject'] = 'Test Email via SMTP Gateway'
msg['From'] = 'test@example.com'
msg['To'] = 'recipient@example.com'

# Send via SMTP
{% if local_testing %}
use_ssl = False
{% endif %}
if use_ssl:
    server = smtplib.SMTP_SSL(smtp_host, smtp_port)
else:
    server = smtplib.SMTP(smtp_host, smtp_port)
    server.ehlo()
with server:
    if username and password:
        server.login(username, password)
    server.send_message(msg)
    print('Email sent successfully')
print('connectivity ok')
