import os
import smtplib
from email.mime.text import MIMEText

{% if local_testing %}
# Local testing: render upstream SMTP host/port/credentials directly.
smtp_host = "{{ host }}"
smtp_port = {{ port | default(587) }}
use_ssl = "{{ tls | default('False') }}" == "True"
username = "{{ username | default('') }}"
password = "{{ password | default('') }}"
{% else %}
# Gateway: SERVICE_BASE_URL is smtp://host:port or smtps://host:port.
# Username comes from the listing's routing_key; password is the customer's
# API key (never inlined into rendered output, so still pulled from env).
from urllib.parse import urlparse

parsed = urlparse("{{ service_base_url }}")
smtp_host = parsed.hostname
smtp_port = parsed.port or 587
use_ssl = parsed.scheme == "smtps"
username = "{{ routing_key.username }}"
password = os.environ["UNITYSVC_API_KEY"]
{% endif %}

msg = MIMEText("Hello from UnitySVC SMTP Gateway!")
msg["Subject"] = "Test Email via SMTP Gateway"
msg["From"] = "test@example.com"
msg["To"] = "recipient@example.com"

if use_ssl:
    with smtplib.SMTP_SSL(smtp_host, smtp_port, timeout=10) as server:
        if username and password:
            server.login(username, password)
        server.send_message(msg)
else:
    with smtplib.SMTP(smtp_host, smtp_port, timeout=10) as server:
        server.ehlo()
        if server.has_extn("STARTTLS"):
            server.starttls()
            server.ehlo()
        if username and password:
            server.login(username, password)
        server.send_message(msg)
print("connectivity ok")
