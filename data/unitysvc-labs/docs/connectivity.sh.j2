#!/bin/bash
# Test SMTP gateway connectivity
{% if local_testing %}
# Local testing: check if mailpit SMTP is reachable
echo "QUIT" | nc -w5 ${SMTP_HOST:-mailpit} ${SMTP_PORT:-1025} | grep -q "220" && echo "connectivity ok"
{% else %}
# Test via SMTP gateway
echo "QUIT" | nc -w5 ${SMTP_HOST:-localhost} ${SMTP_PORT:-2587} | grep -q "220" && echo "connectivity ok"
{% endif %}
