#!/bin/bash
# Test SMTP connectivity
{% if local_testing %}
# Local testing: check if upstream SMTP is reachable
(sleep 1; echo "QUIT") | nc -w5 ${HOST:-localhost} ${PORT:-587} | grep -q "220" && echo "connectivity ok"
{% else %}
# Test via SMTP gateway
(sleep 1; echo "QUIT") | nc -w5 ${SMTP_HOST:-localhost} ${SMTP_PORT:-2587} | grep -q "220" && echo "connectivity ok"
{% endif %}
